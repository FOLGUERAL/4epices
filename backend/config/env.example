HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified

# Database
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Pour PostgreSQL en production, décommenter et utiliser :
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=4epices
# DATABASE_USERNAME=your_username
# DATABASE_PASSWORD=your_password
# DATABASE_SSL=false

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000

# Pinterest API (à configurer)
# IMPORTANT: Le token doit avoir les scopes suivants :
# pins:read, pins:write, boards:read, boards:write, user_accounts:read
# Voir PINTEREST_TOKEN_SCOPES.md pour obtenir un token avec les bons scopes
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# Pinterest Boards multiples (optionnel)
# Board secondaire (fallback si aucun board saisonnier configuré)
PINTEREST_BOARD_SECONDARY=

# Boards saisonniers (optionnel)
# Board pour automne/hiver (utilisé de septembre à mars)
PINTEREST_BOARD_SEASONAL_AUTOMNE_HIVER=
# Board pour printemps/été (utilisé de mars à septembre)
PINTEREST_BOARD_SEASONAL_PRINTEMPS_ETE=

# Pinterest OAuth (recommandé pour la démo Pinterest)
# Dans Pinterest Developer Portal, ajouter PINTEREST_REDIRECT_URI dans la liste des redirect URIs autorisées.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Doit être une URL ABSOLUE vers le callback Strapi, ex:
# http://localhost:1337/api/pinterest/callback
PINTEREST_REDIRECT_URI=

# Optionnel: où rediriger l'utilisateur après succès OAuth
# Par défaut: {FRONTEND_URL}/admin?pinterest=connected
PINTEREST_POST_AUTH_REDIRECT=

# Configuration IA pour génération de contenu Pinterest (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Configuration Groq pour retouche d'images (Vision)
# ⚠️ llama-3.2-90b-vision-preview est décommissionné
# Modèles avec vision disponibles: llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=llama-4-scout-17b-16e-instruct

# Configuration pour génération d'images améliorées (optionnel)
# Option 1: Hugging Face (GRATUIT - peut avoir des limitations)
# Obtenez votre token sur https://huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=
# Modèle à utiliser (par défaut: runwayml/stable-diffusion-v1-5)
# HUGGINGFACE_IMAGE_MODEL=runwayml/stable-diffusion-v1-5

# Option 2: Replicate (PAYANT - ~$0.002-0.01/image)
# Obtenez votre token sur https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=
# Modèle à utiliser (par défaut: stability-ai/sdxl)
# REPLICATE_IMAGE_MODEL=stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b