{
  "kind": "collectionType",
  "collectionName": "avis",
  "info": {
    "singularName": "avis",
    "pluralName": "avis-recettes",
    "displayName": "Avis",
    "description": "Avis et notes des utilisateurs sur les recettes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "recette": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::recette.recette",
      "inversedBy": "avis"
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "comment": {
      "type": "text",
      "required": false
    },
    "author": {
      "type": "string",
      "required": false,
      "maxLength": 255
    },
    "approuve": {
      "type": "boolean",
      "default": false
    }
  }
}
